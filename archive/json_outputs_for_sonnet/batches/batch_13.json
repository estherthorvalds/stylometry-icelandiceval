{
  "batch": 13,
  "headlines": [
    {
      "index": 0,
      "text": "Pálínuboð og listamannaspjall"
    },
    {
      "index": 1,
      "text": "Vináttudagurinn í Blönduskóla"
    },
    {
      "index": 2,
      "text": "Nýr framkvæmdastjóri Selaseturs Íslands"
    },
    {
      "index": 3,
      "text": "Sviðamessa Lionsklúbbs Blönduóss"
    },
    {
      "index": 4,
      "text": "Sjúkrabílum á landsbyggðinni fækkar"
    },
    {
      "index": 5,
      "text": "Ný hitaveita tekin í notkun á Skagaströnd"
    },
    {
      "index": 6,
      "text": "Selasigling á Hvammstanga hlaut Hvatningarverðlaunin"
    },
    {
      "index": 7,
      "text": "Súpuleikhúsið \"Algjör súpa\""
    },
    {
      "index": 8,
      "text": "Pólitískar ofsóknir á Alþingi"
    },
    {
      "index": 9,
      "text": "Skuldaleiðréttingar, er umræðan sanngjörn?"
    },
    {
      "index": 10,
      "text": "Sjávarútvegsráðherra fer með ósannindi"
    },
    {
      "index": 11,
      "text": "Makríll: 32 milljarða kr. ósóttur vinningur"
    },
    {
      "index": 12,
      "text": "Komum okkur á kortið!"
    },
    {
      "index": 13,
      "text": "Skjaldborgin um kvótakerfið fremur en fólkið"
    },
    {
      "index": 14,
      "text": "Nóvembernöldur"
    },
    {
      "index": 15,
      "text": "Hittingur í Perlunni á laugardaginn"
    },
    {
      "index": 16,
      "text": "Samstarfssamningur um dreifnám í A-Hún. undirritaður"
    },
    {
      "index": 17,
      "text": "Guðsþjónusta og kaffihlaðborð"
    },
    {
      "index": 18,
      "text": "Neyðarkall seldur á Hvammstanga"
    },
    {
      "index": 19,
      "text": "Bjartsýnn á gagnaver"
    },
    {
      "index": 20,
      "text": "Spilakvöld í Húnavallaskóla"
    },
    {
      "index": 21,
      "text": "Dagur atvinnulífsins á Norðurlandi vestra"
    },
    {
      "index": 22,
      "text": "Lækjamót valið ræktunarbú ársins"
    },
    {
      "index": 23,
      "text": "Handverksfólk! Vantar ykkur ráðgjöf?"
    },
    {
      "index": 24,
      "text": "Hugarflug um handverk"
    },
    {
      "index": 25,
      "text": "Gott fiskirí á Húnaflóa"
    },
    {
      "index": 26,
      "text": "65 börn og unglingar tóku þátt í æskulýðsstarfi Þyts"
    },
    {
      "index": 27,
      "text": "Fyrstu húsin tengjast í vikunni"
    },
    {
      "index": 28,
      "text": "Sláturtíðin gengið vel á Blönduósi"
    },
    {
      "index": 29,
      "text": "Nýir leigutakar að Víðidalsá og Fitjaá"
    },
    {
      "index": 30,
      "text": "Uppskeruhátíðir hestafólks í Húnaþingi vestra"
    },
    {
      "index": 31,
      "text": "Skáldin á Skagaströnd"
    },
    {
      "index": 32,
      "text": "Eftirlitið heim í hérað"
    },
    {
      "index": 33,
      "text": "Happdrætti Styrktarsjóðs Húnvetninga í sölu á Blönduósi"
    },
    {
      "index": 34,
      "text": "Heita vatnið er komið til Skagastrandar"
    },
    {
      "index": 35,
      "text": "Skorað á stjórnvöld að fylgja Sóknaráætlun landshluta eftir af heilum hug"
    },
    {
      "index": 36,
      "text": "Byggja þarf upp greiðari samgöngur"
    },
    {
      "index": 37,
      "text": "Allur akstur utan vega er óheimill"
    },
    {
      "index": 38,
      "text": "Heita vatnið kemur til Skagastrandar"
    },
    {
      "index": 39,
      "text": "Græn lína hjá Vilko"
    }
  ]
}