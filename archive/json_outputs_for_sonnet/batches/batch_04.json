{
  "batch": 4,
  "headlines": [
    {
      "index": 0,
      "text": "Kór Vídalínskirkju í Garðabæ á tónleikaferð um Norðurland vestra"
    },
    {
      "index": 1,
      "text": "Sól og vor ég syng um"
    },
    {
      "index": 2,
      "text": "Vantar eitthvað íslenskt"
    },
    {
      "index": 3,
      "text": "Harpa Birgisdóttir fékk Morgunblaðsskeifuna á Skeifudegi Grana á Hvanneyri"
    },
    {
      "index": 4,
      "text": "Framsókn stærst í NV-kjördæmi"
    },
    {
      "index": 5,
      "text": "Kosningavaka í kaffihúsinu Við ábakkann"
    },
    {
      "index": 6,
      "text": "Starfsfólk Blönduósbæjar í starfs- og kynnisferð"
    },
    {
      "index": 7,
      "text": "Naglasúpa í Bjarmanesi og opið hús"
    },
    {
      "index": 8,
      "text": "Kosningakaffi Samfylkingarinnar"
    },
    {
      "index": 9,
      "text": "Afmælissýningu Neista frestað"
    },
    {
      "index": 10,
      "text": "Sæluvika Skagafirðinga hefst á sunnudaginn"
    },
    {
      "index": 11,
      "text": "Hvað er að vera jafnaðarmaður?"
    },
    {
      "index": 12,
      "text": "Kosningakaffi Samfylkingarinnar"
    },
    {
      "index": 13,
      "text": "Kosningakaffi Framsóknarflokksins fram að kosningum"
    },
    {
      "index": 14,
      "text": "Sigurður hættir hjá SAH Afurðum"
    },
    {
      "index": 15,
      "text": "Sundklukka vígð í Íþróttamiðstöðinni á Blönduósi"
    },
    {
      "index": 16,
      "text": "Gleðilegt sumar"
    },
    {
      "index": 17,
      "text": "Sumarskemmtun Blönduskóla og kökubasar"
    },
    {
      "index": 18,
      "text": "Opinn fundur með Bjarna Benediktssyni, formanni Sjálfstæðisflokksins"
    },
    {
      "index": 19,
      "text": "Ekki þörf fyrir fjármálastjóra"
    },
    {
      "index": 20,
      "text": "Sumarstörf hjá Sveitarfélaginu Skagaströnd"
    },
    {
      "index": 21,
      "text": "Kosningakaffi - kosningasamvera"
    },
    {
      "index": 22,
      "text": "Nú er komið að vorgleði Lóuþræla"
    },
    {
      "index": 23,
      "text": "Lífsdans Geirmundar Valtýssonar í Hofi"
    },
    {
      "index": 24,
      "text": "Fyrirlestur í Laxasetrinu"
    },
    {
      "index": 25,
      "text": "Stöndum saman - afnemum verðbólgu"
    },
    {
      "index": 26,
      "text": "Barna og unglinga guðþjónusta og fermingar í Þingeyraklaustursprestakalli"
    },
    {
      "index": 27,
      "text": "Virkjanir á veituleið Blönduvirkjunar"
    },
    {
      "index": 28,
      "text": "Stórgóð skákheimsókn á Blönduós - upphafsstað skáksambandsins"
    },
    {
      "index": 29,
      "text": "10 milljarða gjöf VG og S úr galtómum ríkissjóði - á ári"
    },
    {
      "index": 30,
      "text": "Lífið á Blönduósi og í næsta nágrenni um helgina"
    },
    {
      "index": 31,
      "text": "Aðalfundur Samstöðu"
    },
    {
      "index": 32,
      "text": "Óskað eftir umsóknum um styrki"
    },
    {
      "index": 33,
      "text": "Lokakeppnin í spurningakeppni átthagafélaganna"
    },
    {
      "index": 34,
      "text": "Afmælissýning Neista"
    },
    {
      "index": 35,
      "text": "Varmahlíðarskóli vann fimmta árið í röð"
    },
    {
      "index": 36,
      "text": "Lúsífer vakti athygli og aðdáun"
    },
    {
      "index": 37,
      "text": "Íbúð á Suðureyri við Súgandafjörð - Vestfirðir"
    },
    {
      "index": 38,
      "text": "Verkefnisstjórn skipuð vegna átaks í atvinnu- og markaðsmálum í Húnaþingi vestra"
    },
    {
      "index": 39,
      "text": "Íþróttamiðstöðin fær sundskáksett að gjöf"
    }
  ]
}