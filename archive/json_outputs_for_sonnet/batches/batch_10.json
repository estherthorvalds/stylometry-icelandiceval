{
  "batch": 10,
  "headlines": [
    {
      "index": 0,
      "text": "Rækjuvinnsla aftur á Hvammstanga"
    },
    {
      "index": 1,
      "text": "Lagning hitakerfis í leikskólann Barnaból"
    },
    {
      "index": 2,
      "text": "Verkefni til vekja athygli á gamla bænum"
    },
    {
      "index": 3,
      "text": "Mótaröð Neista fór vel af stað"
    },
    {
      "index": 4,
      "text": "Zumba námskeið á Blönduósi"
    },
    {
      "index": 5,
      "text": "Fjör á grímuballi í Félagsheimilinu"
    },
    {
      "index": 6,
      "text": "Endurbætur á Félagsheimilinu"
    },
    {
      "index": 7,
      "text": "Umfjöllun um sameiningu sveitarfélaga í A-Hún."
    },
    {
      "index": 8,
      "text": "Íbúum Blönduóss og Skagastrandar fjölgar"
    },
    {
      "index": 9,
      "text": "Blönduósbær endurfjármagnar afborganir"
    },
    {
      "index": 10,
      "text": "Fjör á 112 deginum á Blönduósi"
    },
    {
      "index": 11,
      "text": "Dreifnám á Hvammstanga reynst mjög vel"
    },
    {
      "index": 12,
      "text": "Þorrablót á Borðeyri"
    },
    {
      "index": 13,
      "text": "Grímuball"
    },
    {
      "index": 14,
      "text": "Mótaröð Neista að hefjast"
    },
    {
      "index": 15,
      "text": "Grunnskólamót hestamannafélaga"
    },
    {
      "index": 16,
      "text": "Frá æfingum upp í afköst"
    },
    {
      "index": 17,
      "text": "112 dagurinn á Blönduósi"
    },
    {
      "index": 18,
      "text": "Neikvæðustu áhrifin sjónræns eðlis"
    },
    {
      "index": 19,
      "text": "Ísgel ehf. á Blönduósi hlaut styrk frá NORA"
    },
    {
      "index": 20,
      "text": "Vetrarfrí í Tónlistarskóla A-Hún."
    },
    {
      "index": 21,
      "text": "Aðalfundur Skotfélagsins Markviss"
    },
    {
      "index": 22,
      "text": "Fyrsta mót Húnvetnsku liðakeppninnar 2013"
    },
    {
      "index": 23,
      "text": "Aðalfundur Sunddeildar Hvatar"
    },
    {
      "index": 24,
      "text": "Vinnustofa um notkun upplýsingatækni í kennslu"
    },
    {
      "index": 25,
      "text": "Spurningakeppni átthagafélaganna 2013"
    },
    {
      "index": 26,
      "text": "Opna listasýningu í tilefni dagsins"
    },
    {
      "index": 27,
      "text": "Potluck á Skagaströnd"
    },
    {
      "index": 28,
      "text": "Talningu atkvæða í NV-kjördæmi lokið"
    },
    {
      "index": 29,
      "text": "Vegslóðanum að Hvítserk lokað"
    },
    {
      "index": 30,
      "text": "112 dagurinn á Blönduósi"
    },
    {
      "index": 31,
      "text": "Blönduósbær auglýsir eftir fjármálastjóra"
    },
    {
      "index": 32,
      "text": "Erlendir listamenn í Kvennaskólanum á Blönduósi"
    },
    {
      "index": 33,
      "text": "Sveitabakarí opnar kaffiteríu sína"
    },
    {
      "index": 34,
      "text": "Hreppaþorrablót 2013 *** BREYTTUR BANKAREIKNINGUR***"
    },
    {
      "index": 35,
      "text": "Slóðinn að Hvítserk stórvarasamur"
    },
    {
      "index": 36,
      "text": "Styttist í Húnvetnsku liðakeppnina"
    },
    {
      "index": 37,
      "text": "Auglýst eftir myndum af byggingu Félagsheimilisins"
    },
    {
      "index": 38,
      "text": "Smábæjaleikarnir í fullum undirbúningi"
    },
    {
      "index": 39,
      "text": "Skemmtilegt ísmót á Gauksmýrartjörn"
    }
  ]
}