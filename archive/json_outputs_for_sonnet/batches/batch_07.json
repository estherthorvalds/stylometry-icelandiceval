{
  "batch": 7,
  "headlines": [
    {
      "index": 0,
      "text": "Árangur í efnahagsmálum"
    },
    {
      "index": 1,
      "text": "Sjálfstæðisflokkurinn jók framlög til velferðarmála"
    },
    {
      "index": 2,
      "text": "Skýra stefnu í byggðamálum"
    },
    {
      "index": 3,
      "text": "Bann við frjálsum handfæraveiðum er mannréttindabrot!"
    },
    {
      "index": 4,
      "text": "Byggðastefna, strandsvæðastjórn og svæðisgarður"
    },
    {
      "index": 5,
      "text": "Er það þráhyggjan, sem skapar okkur Íslendingum örlög?"
    },
    {
      "index": 6,
      "text": "Aprílnöldur"
    },
    {
      "index": 7,
      "text": "Áhugamálin öll"
    },
    {
      "index": 8,
      "text": "Nemendur Blönduskóla segja þjóðsögur"
    },
    {
      "index": 9,
      "text": "Hlaupanámskeið á Blönduósi"
    },
    {
      "index": 10,
      "text": "Gjafir fyrir 28 milljónir á sjö árum"
    },
    {
      "index": 11,
      "text": "Flipp íþróttamót í Höfðaskóla"
    },
    {
      "index": 12,
      "text": "Sjómannadagskaffi og harmóníkutónleikar"
    },
    {
      "index": 13,
      "text": "Tími nagladekkja er liðinn"
    },
    {
      "index": 14,
      "text": "Lesið í prjón"
    },
    {
      "index": 15,
      "text": "Sjómannadagurinn á Skagaströnd"
    },
    {
      "index": 16,
      "text": "Sjómannadagurinn á Hvammstanga"
    },
    {
      "index": 17,
      "text": "Aðalfundur Vina Kvennaskólans"
    },
    {
      "index": 18,
      "text": "Hagsmunasamtök heimilanna skora á sveitarstjórnir"
    },
    {
      "index": 19,
      "text": "SEEDS kynnir spennandi ungmennaskipti fyrir ungt fólk á Ítalíu"
    },
    {
      "index": 20,
      "text": "Fundur með hagsmunaaðilum vegna Húnavöku"
    },
    {
      "index": 21,
      "text": "Fatasala í Félagsheimilinu á föstudaginn"
    },
    {
      "index": 22,
      "text": "Hitaveituframkvæmdir á Blönduósi"
    },
    {
      "index": 23,
      "text": "Þrjár vorsýningar voru á Blönduósi í gær"
    },
    {
      "index": 24,
      "text": "Húnavökurit USAH 2013 er komið út"
    },
    {
      "index": 25,
      "text": "Kvennareiðtúr"
    },
    {
      "index": 26,
      "text": "Luku prófi í knapamerki 4"
    },
    {
      "index": 27,
      "text": "Styttist í opnun Blöndu"
    },
    {
      "index": 28,
      "text": "Flateyjarbók til sýnis á Þingeyrum"
    },
    {
      "index": 29,
      "text": "Opið hús í Nesi listamiðstöð"
    },
    {
      "index": 30,
      "text": "Innritun í Tónlistarskóla A-Hún. í næstu viku"
    },
    {
      "index": 31,
      "text": "Handverkssýning, vorsýning og opið hús"
    },
    {
      "index": 32,
      "text": "Dreifnám í Austur-Húnavatnssýslu hefst í haust"
    },
    {
      "index": 33,
      "text": "Eyðibýli á Íslandi - sumarið 2013"
    },
    {
      "index": 34,
      "text": "Fjölskylduferð Húnvetningafélagsins"
    },
    {
      "index": 35,
      "text": "Félagar í Markviss gera það gott"
    },
    {
      "index": 36,
      "text": "Líf að færast yfir höfnina á Skagaströnd"
    },
    {
      "index": 37,
      "text": "Systkinin Eysteinn Pétur og Kristín Ingibjörg verða umsjónaraðilar Húnavöku 2013"
    },
    {
      "index": 38,
      "text": "Framkvæmdir við hitaveitu hafnar á Skagaströnd"
    },
    {
      "index": 39,
      "text": "Á fimmtánda þúsund aðilar hafa fengið Íslykil"
    }
  ]
}