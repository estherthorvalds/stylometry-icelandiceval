{
  "batch": 8,
  "headlines": [
    {
      "index": 0,
      "text": "Húni II kemur í sína gömlu heimahöfn eftir 50 ár"
    },
    {
      "index": 1,
      "text": "Kiwanishreyfingin gefur hjálma"
    },
    {
      "index": 2,
      "text": "Gáfu Húnavallaskóla endurskinsvesti"
    },
    {
      "index": 3,
      "text": "Kjalvegur ekki boðleg ökuleið"
    },
    {
      "index": 4,
      "text": "Sumarstarf námsmanna hjá Sýslumanninum á Blönduósi"
    },
    {
      "index": 5,
      "text": "Húni II og Knörrinn á Skagaströnd í kvöld"
    },
    {
      "index": 6,
      "text": "Húnabjörg kölluð út"
    },
    {
      "index": 7,
      "text": "Sumarstörf námsmanna auglýst"
    },
    {
      "index": 8,
      "text": "Sólin þaggar þokugrát - Vortónleikar"
    },
    {
      "index": 9,
      "text": "Keypti hesta fyrir um 100 milljónir"
    },
    {
      "index": 10,
      "text": "Hitaveituframkvæmdir hafa neikvæð áhrif á rekstrarniðurstöðu"
    },
    {
      "index": 11,
      "text": "Sumaropnun Bardúsa"
    },
    {
      "index": 12,
      "text": "Skólaslit Tónlistarskóla A-Hún. verða í Blönduóskirkju á laugardaginn"
    },
    {
      "index": 13,
      "text": "Tímamót í fjarskiptamálum Skagastrandar"
    },
    {
      "index": 14,
      "text": "Þarfagreining náms á Norðurlandi vestra"
    },
    {
      "index": 15,
      "text": "„Allir öruggir heim“ - endurskinsvesti fyrir börn"
    },
    {
      "index": 16,
      "text": "Hagnaður í Húnaþingi vestra"
    },
    {
      "index": 17,
      "text": "Ævintýraferð í Vatnahverfi"
    },
    {
      "index": 18,
      "text": "Húnavatnshreppur endurbætir netsamband"
    },
    {
      "index": 19,
      "text": "Pub Quiz á Pottinum á föstudaginn"
    },
    {
      "index": 20,
      "text": "Viltu taka þátt í vöruþróun?"
    },
    {
      "index": 21,
      "text": "Leitað að nýjum umsjónaraðila að Húnavöku"
    },
    {
      "index": 22,
      "text": "Nemandi úr Höfðaskóla vann í stærðfræðikeppni"
    },
    {
      "index": 23,
      "text": "Vatnahverfisvöllur handmokaður fyrir fyrsta mót"
    },
    {
      "index": 24,
      "text": "Námskeið í stjórn og meðferð vinnuvéla"
    },
    {
      "index": 25,
      "text": "Erlendur auðmaður fjármagnar hesthús í Víðidal"
    },
    {
      "index": 26,
      "text": "Héraðsmót í sundi."
    },
    {
      "index": 27,
      "text": "Skil á skattframtali vegna húsaleigubóta"
    },
    {
      "index": 28,
      "text": "Göngum saman á Blönduósi"
    },
    {
      "index": 29,
      "text": "Markaður í Félagsheimilinu á Blönduósi"
    },
    {
      "index": 30,
      "text": "Afmælissýning Neista tókst vel"
    },
    {
      "index": 31,
      "text": "Markvissmenn skeltu sér á námskeið í skyndihjálp"
    },
    {
      "index": 32,
      "text": "Önnur sýning á kvikmyndinni \"Svart og hvítt\" á morgun"
    },
    {
      "index": 33,
      "text": "Kiwanishreyfingin gefur reiðhjólahjálma"
    },
    {
      "index": 34,
      "text": "Íþróttamiðstöðin auglýsir eftir starfskrafti"
    },
    {
      "index": 35,
      "text": "Fyrirlestur um Guðmund Björnsson landlækni"
    },
    {
      "index": 36,
      "text": "Aðalfundur Húnvetningafélagsins í Reykjavík"
    },
    {
      "index": 37,
      "text": "Leirdúfuskotfimitímabilið er hafið"
    },
    {
      "index": 38,
      "text": "Afmælissýning Neista í Reiðhöllinni Arnargerði"
    },
    {
      "index": 39,
      "text": "Handverkssýning og kaffihlaðborð"
    }
  ]
}