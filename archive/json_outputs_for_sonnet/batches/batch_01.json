{
  "batch": 1,
  "headlines": [
    {
      "index": 0,
      "text": "Ýmislegt um að vera á Blönduósi um helgina"
    },
    {
      "index": 1,
      "text": "Vorfagnaður á Borðeyri"
    },
    {
      "index": 2,
      "text": "Bæjarstjórn Blönduósbæjar heimsótti Skagaströnd"
    },
    {
      "index": 3,
      "text": "Jón leiðir Regnbogann í NV-kjördæmi"
    },
    {
      "index": 4,
      "text": "Frítt í þrek og sund fyrir eldri borgara í apríl"
    },
    {
      "index": 5,
      "text": "Söngnámskeið með fræðilegu ívafi"
    },
    {
      "index": 6,
      "text": "Markvert sér um Húnavöku 2013"
    },
    {
      "index": 7,
      "text": "Sumarstörf hjá Blönduósbæ auglýst"
    },
    {
      "index": 8,
      "text": "Páska-Zumba-partý í Íþróttamiðstöðinni"
    },
    {
      "index": 9,
      "text": "Samningar vegna Sóknaráætlana landshluta undirritaðir"
    },
    {
      "index": 10,
      "text": "Lionsklúbbur Blönduóss styrkir góð málefni"
    },
    {
      "index": 11,
      "text": "Ný aðalnámskrá grunnskóla - nýjar áherslur"
    },
    {
      "index": 12,
      "text": "Ýmislegt spennandi framundan hjá Textílsetrinu"
    },
    {
      "index": 13,
      "text": "Eldur í Húnaþingi fer fram 24.-27. júlí"
    },
    {
      "index": 14,
      "text": "Framboðslisti Dögunar í NV-kjördæmi"
    },
    {
      "index": 15,
      "text": "Töltmót Neista - úrslit"
    },
    {
      "index": 16,
      "text": "Kampselur heimsótti okkur Blönduósinga"
    },
    {
      "index": 17,
      "text": "Devlin Shea með listasýningu í Gúttó"
    },
    {
      "index": 18,
      "text": "Helstu niðurstöður íbúaþings á Skagaströnd"
    },
    {
      "index": 19,
      "text": "Góð mæting á bíókvöld Gleðibankans"
    },
    {
      "index": 20,
      "text": "Samið um ráðgjafaþjónusta"
    },
    {
      "index": 21,
      "text": "Keppendur Blönduskóla í Skólahreysti urðu í 3. sæti"
    },
    {
      "index": 22,
      "text": "Meleyri komin aftur í rekstur"
    },
    {
      "index": 23,
      "text": "Pub-quiz á Pottinum í kvöld"
    },
    {
      "index": 24,
      "text": "Frítt í bíó á Blönduósi"
    },
    {
      "index": 25,
      "text": "Mótaröð Neista - Tölt"
    },
    {
      "index": 26,
      "text": "Messur og helgihald um páska í Þingeyraklaustursprestakalli"
    },
    {
      "index": 27,
      "text": "Páskamót Jako og Hvatar í knattspyrnu fyrir 6. - 7. flokk"
    },
    {
      "index": 28,
      "text": "Aðalfundur Samfylkingarfélags A. Hún"
    },
    {
      "index": 29,
      "text": "Bíósýningar í Selasetrinu um helgina"
    },
    {
      "index": 30,
      "text": "Opinn fundur með Árna Páli á Blönduósi í kvöld"
    },
    {
      "index": 31,
      "text": "Aðalfundur Foreldrafélags Blönduskóla er í kvöld"
    },
    {
      "index": 32,
      "text": "„Lífsafkomu bænda ógnað“"
    },
    {
      "index": 33,
      "text": "Vetrarleikar Neista fóru fram í frábæru veðri"
    },
    {
      "index": 34,
      "text": "Fundur í bæjarstjórn Blönduósbæjar"
    },
    {
      "index": 35,
      "text": "Verkefni um héraðsfréttamiðla"
    },
    {
      "index": 36,
      "text": "Fjársjóður í fjölskyldualbúminu"
    },
    {
      "index": 37,
      "text": "Mikil spenna í Húnvetnsku liðakeppninni"
    },
    {
      "index": 38,
      "text": "Kjör í stjórnir og nefndir Samstöðu"
    },
    {
      "index": 39,
      "text": "Farskólinn á ferðinni á Blönduósi"
    }
  ]
}