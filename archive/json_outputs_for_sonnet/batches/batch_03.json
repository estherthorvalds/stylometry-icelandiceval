{
  "batch": 3,
  "headlines": [
    {
      "index": 0,
      "text": "Tvískiptir kynningafundir um dreifnám"
    },
    {
      "index": 1,
      "text": "Reiðhjólamanni bjargað"
    },
    {
      "index": 2,
      "text": "Íbúaþing á Skagaströnd"
    },
    {
      "index": 3,
      "text": "96. ársþing USAH fór fram um helgina á Blönduósi"
    },
    {
      "index": 4,
      "text": "Fræðsla um notendastýrða persónulega aðstoð og sjálfstætt líf"
    },
    {
      "index": 5,
      "text": "Fengu vel búnar verkfærakistur að gjöf"
    },
    {
      "index": 6,
      "text": "Vertu á verði - Átak gegn verðhækkunum"
    },
    {
      "index": 7,
      "text": "Al-Anon á Blönduósi"
    },
    {
      "index": 8,
      "text": "Fitan er auðlind en ekki vandamál"
    },
    {
      "index": 9,
      "text": "Blönduskóli á fulltrúa á Söngkeppni SAMFÉS á morgun"
    },
    {
      "index": 10,
      "text": "Björt framtíð í sveitum og þorpum"
    },
    {
      "index": 11,
      "text": "Hugurinn ber okkur hálfa leið"
    },
    {
      "index": 12,
      "text": "Ný íslensk mynt - Stórir ávinningar"
    },
    {
      "index": 13,
      "text": "Þorpin eiga að lifa"
    },
    {
      "index": 14,
      "text": "Leiðrétting verðtryggðra húsnæðislána - Tækifæri til að skapa nýja framtíð"
    },
    {
      "index": 15,
      "text": "Innrásin í Írak - til hvers?"
    },
    {
      "index": 16,
      "text": "Landsbyggðarskattur Framsóknar"
    },
    {
      "index": 17,
      "text": "Vilt þú að húsnæðislánið þitt verði lækkað um 45%?"
    },
    {
      "index": 18,
      "text": "Draumalandið"
    },
    {
      "index": 19,
      "text": "Horfa þarf til framtíðar"
    },
    {
      "index": 20,
      "text": "Byggðastefna, grunnþjónusta og auðlindagjald"
    },
    {
      "index": 21,
      "text": "Lágmarkslaun lögbundin, hækkun skattleysismarka, lækkun gjalda"
    },
    {
      "index": 22,
      "text": "Fjögur ár mikilla tíðinda!"
    },
    {
      "index": 23,
      "text": "Kosningar framundan"
    },
    {
      "index": 24,
      "text": "Vansæll varabæjarfulltrúi og frambjóðandi Samfylkingarinnar"
    },
    {
      "index": 25,
      "text": "Herferð gegn verðtryggingunni"
    },
    {
      "index": 26,
      "text": "Siglufjörður og samfélagsfrumkvöðlarnir"
    },
    {
      "index": 27,
      "text": "Hvað finnst þér um að auka fiskveiðar?"
    },
    {
      "index": 28,
      "text": "Allt í himnalagi?"
    },
    {
      "index": 29,
      "text": "Aukin áhrif í evrópusamstarfi"
    },
    {
      "index": 30,
      "text": "Um bæjarmál á Blönduósi"
    },
    {
      "index": 31,
      "text": "Hagkerfin tvö"
    },
    {
      "index": 32,
      "text": "Allir útreikningar Vilhjálms hraktir"
    },
    {
      "index": 33,
      "text": "Aldraðir"
    },
    {
      "index": 34,
      "text": "Marsnöldur"
    },
    {
      "index": 35,
      "text": "Kaupmáttur - Atvinna - Velferð"
    },
    {
      "index": 36,
      "text": "Bíómyndin Svart og hvítt frumsýnd í Félagsheimilinu"
    },
    {
      "index": 37,
      "text": "Vortónleikar Lillukórsins á Hvammstanga"
    },
    {
      "index": 38,
      "text": "Vortónleikar Tónlistarskóla A-Hún."
    },
    {
      "index": 39,
      "text": "Heimur sjónhverfinga í Félagsheimilinu"
    }
  ]
}