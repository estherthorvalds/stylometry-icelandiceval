      "text": "Menningardagur í Húnabúð"
    },
    {
      "index": 29,
      "text": "Styrkumsóknir úr bæjarsjóði fyrir árið 2014"
    },
    {
      "index": 30,
      "text": "Mögnuð sjón að sjá stóðið koma"
