    {
      "index": 4,
      "text": "Fatamarkaður RKÍ"
    },
    {
      "index": 5,
      "text": "Lomberkvöld í Húnabúð"
    },
    {
      "index": 6,
      "text": "495 tonna byggðakvóti í Húnavatnssýslur"
