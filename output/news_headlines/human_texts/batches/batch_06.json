{
  "batch": 6,
  "headlines": [
    {
      "index": 0,
      "text": "Aðalfundur Ferðamálasamtaka Norðurlands vestra"
    },
    {
      "index": 1,
      "text": "Lokamót Mótaraðar Neista"
    },
    {
      "index": 2,
      "text": "Opnun sýningar í Textílsetrinu"
    },
    {
      "index": 3,
      "text": "Vorferð kúabænda í A.-Hún."
    },
    {
      "index": 4,
      "text": "Nýtt Zumba-námskeið að hefjast"
    },
    {
      "index": 5,
      "text": "Hvað á ég eiginlega að borða?"
    },
    {
      "index": 6,
      "text": "Englandsferðir nemenda og kennara Blönduskóla"
    },
    {
      "index": 7,
      "text": "Lokamót Húnvetnsku liðakeppninnar"
    },
    {
      "index": 8,
      "text": "Flokkur heimilanna bíður fram í NV-kjördæmi"
    },
    {
      "index": 9,
      "text": "Aprílgabb á Húnahorninu"
    },
    {
      "index": 10,
      "text": "Héraðsþing USVH"
    },
    {
      "index": 11,
      "text": "Við þökkum fyrir okkur"
    },
    {
      "index": 12,
      "text": "Kastaðu ekki atkvæði þínu á glæ - Kjóstu öfluga málsvara fyrir landsbyggðina"
    },
    {
      "index": 13,
      "text": "Jón Bjarnason stendur við sitt"
    },
    {
      "index": 14,
      "text": "Er valið nokkuð svo erfitt?"
    },
    {
      "index": 15,
      "text": "Ríkið fækkaði störfum á Norðurlandi vestra"
    },
    {
      "index": 16,
      "text": "Byggðastefna hefðbundinna atvinnuhátta"
    },
    {
      "index": 17,
      "text": "Hagfelldar aðgerðir í þágu lands og þjóðar"
    },
    {
      "index": 18,
      "text": "Hagkvæmar, raunsæjar og tímasettar lausnir á efnahagsvanda þjóðarinnar"
    },
    {
      "index": 19,
      "text": "Trú, von og pólitík"
    },
    {
      "index": 20,
      "text": "Samstöðuleið til betri lífskjara"
    },
    {
      "index": 21,
      "text": "Nauðsynlegar aðgerðir í þágu aldraðra og fatlaðra"
    },
    {
      "index": 22,
      "text": "Guðbjartur er góð fyrirmynd"
    },
    {
      "index": 23,
      "text": "Auðlindaákvæði Framsóknarflokksins"
    },
    {
      "index": 24,
      "text": "Er jafnræði á Íslandi?"
    },
    {
      "index": 25,
      "text": "Biðin langa?"
    },
    {
      "index": 26,
      "text": "Nokkur skynsamleg atriði um auðlindirnar og umhverfið"
    },
    {
      "index": 27,
      "text": "Menntun á forsendum nemenda"
    },
    {
      "index": 28,
      "text": "Allt er breytingum háð"
    },
    {
      "index": 29,
      "text": "Skapandi stjórnunarhættir - minna vesen, minni sóun, meiri sátt"
    },
    {
      "index": 30,
      "text": "Nýttu rétt þinn til að hafa áhrif"
    },
    {
      "index": 31,
      "text": "Krafan um jöfnuð er ekki klisja"
    },
    {
      "index": 32,
      "text": "Hægri grænir vilja að áríðandi aðgerðir hefjist án tafar í þágu fólksins"
    },
    {
      "index": 33,
      "text": "Byggðastefna sem virkar"
    },
    {
      "index": 34,
      "text": "Utankjörfundaratkvæðagreiðsla"
    },
    {
      "index": 35,
      "text": "Íslenskt ríkisfang dugar ekki til"
    },
    {
      "index": 36,
      "text": "Framtíðin getur verið björt um land allt"
    },
    {
      "index": 37,
      "text": "Þakkir fyrir stuðninginn"
    },
    {
      "index": 38,
      "text": "Uppbygging hjúkrunar- og dvalarheimila í NV-kjördæmi"
    },
    {
      "index": 39,
      "text": "Tekið frá sjúkum, öldruðum og öryrkjum og gefið tekjuháum"
    }
  ]
}